<script>
  const otterArt = [
    '     ~~~~  ~~~~~  ~~~~',
    '   ~~   (\\_/)   ~~',
    '  ~~    ( . .)    ~~',
    '   ~~    (")(")   ~~',
    '     ~~~~  ~~~~~  ~~~~',
    '        splish splash',
  ].join('\n');

  function burstOtters() {
    const container = document.createElement('div');
    container.setAttribute('aria-hidden', 'true');
    container.className = 'pointer-events-none fixed inset-0 z-50 overflow-hidden';

    const count = 14;
    for (let i = 0; i < count; i++) {
      const span = document.createElement('span');
      span.textContent = '\u{1F9A6}';
      const left = Math.random() * 100;
      const duration = 2.2 + Math.random() * 1.4;
      const delay = Math.random() * 0.6;
      const size = 1.2 + Math.random() * 1.4;
      span.style.cssText = `
        position: absolute;
        left: ${left}vw;
        bottom: -10vh;
        font-size: ${size}rem;
        animation: otter-float ${duration}s ease-in ${delay}s forwards;
      `;
      container.appendChild(span);
    }

    document.body.appendChild(container);
    setTimeout(() => container.remove(), 4200);
  }

  const style = document.createElement('style');
  style.textContent = `
    @keyframes otter-float {
      0% { transform: translateY(0) rotate(0deg); opacity: 0; }
      10% { opacity: 1; }
      100% { transform: translateY(-110vh) rotate(20deg); opacity: 0; }
    }
  `;
  document.head.appendChild(style);

  Object.defineProperty(window, 'otter', {
    value: () => {
      console.log(otterArt);
      window.dispatchEvent(new CustomEvent('otter-easter-egg'));
      return 'Splash! Nice find.';
    },
    writable: false,
  });

  window.addEventListener('otter-easter-egg', burstOtters);

  let buffer = '';
  window.addEventListener('keydown', (e) => {
    if (e.key.length !== 1) return;
    buffer = (buffer + e.key).slice(-5).toLowerCase();
    if (buffer === 'otter') {
      buffer = '';
      window.dispatchEvent(new CustomEvent('otter-easter-egg'));
    }
  });

  console.log('%cHey, curious mind.', 'font-size: 16px; font-weight: bold; color: #14b8a6;');
  console.log('You found the console. That already puts you ahead of most visitors here.');
  console.log('Try typing otter() and pressing enter.');
</script>
