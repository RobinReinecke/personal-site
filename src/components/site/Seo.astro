---
import { AUTHOR_NAME, SITE_LOCALE, SITE_TITLE } from '../../consts';

interface Props {
  /** Full <title> text. */
  title: string;
  /** Meta + OG/Twitter description. */
  description: string;
  /** Absolute canonical URL for this page. */
  canonical: URL | string;
  /** Absolute URL of the preview image (1200x630). */
  image: URL | string;
  /** Alt text describing the preview image. */
  imageAlt?: string;
  /** Open Graph object type. */
  type?: 'website' | 'article';
  /** ISO date the article was published (articles only). */
  publishedTime?: string;
  /** ISO date the article was last modified (articles only). */
  modifiedTime?: string;
  /** Article tags, emitted as article:tag (articles only). */
  tags?: string[];
  /** Set true to keep the page out of search indexes. */
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  image,
  imageAlt = SITE_TITLE,
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
  noindex = false,
} = Astro.props;

const canonicalStr = canonical.toString();
const imageStr = image.toString();
---

<meta name="description" content={description} />
<link rel="canonical" href={canonicalStr} />
<meta name="author" content={AUTHOR_NAME} />
{
  noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow, max-image-preview:large" />
  )
}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalStr} />
<meta property="og:locale" content={SITE_LOCALE} />
<meta property="og:image" content={imageStr} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={imageAlt} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageStr} />
<meta name="twitter:image:alt" content={imageAlt} />

{
  type === 'article' && (
    <>
      {publishedTime && <meta property="article:published_time" content={publishedTime} />}
      {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
      <meta property="article:author" content={AUTHOR_NAME} />
      {tags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}
    </>
  )
}
