---
import { cn } from '../../lib/utils';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class={cn(
    'prose max-w-none prose-neutral dark:prose-invert',
    'prose-headings:font-semibold prose-a:text-brand prose-a:no-underline hover:prose-a:underline prose-blockquote:border-brand prose-code:rounded prose-code:bg-neutral-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:font-mono prose-code:before:content-none prose-code:after:content-none prose-code:dark:bg-neutral-800',
    className
  )}
>
  <slot />
</div>
