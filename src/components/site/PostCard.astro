---
import type { CollectionEntry } from 'astro:content';
import Card from '../ui/card.astro';
import TagList from './TagList.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const slug = post.data.slug ?? post.id;
const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Card class="group p-6 transition-all hover:-translate-y-0.5 hover:border-brand/40 hover:shadow-md">
  <a href={`/blog/${slug}`} class="block">
    <p class="text-sm text-muted-foreground">{formattedDate}</p>
    <h2 class="mt-1 text-lg font-semibold tracking-tight transition-colors group-hover:text-brand">
      {post.data.title}
    </h2>
    <p class="mt-2 text-sm text-muted-foreground">{post.data.description}</p>
  </a>
  <div class="mt-4">
    <TagList tags={post.data.tags} />
  </div>
</Card>
