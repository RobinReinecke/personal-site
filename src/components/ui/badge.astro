---
import { cn } from '../../lib/utils';

interface Props {
  href?: string;
  class?: string;
}

const { href, class: className } = Astro.props;
const Tag = href ? 'a' : 'span';
---

<Tag
  href={href}
  class={cn(
    'inline-flex items-center rounded-full bg-brand-soft px-2.5 py-0.5 text-xs font-medium text-brand-soft-foreground transition-colors hover:brightness-105',
    className
  )}
>
  <slot />
</Tag>
