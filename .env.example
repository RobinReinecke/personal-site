# Copy to .env and fill in real values. Do not commit .env.

# Postgres password for the umami-db service
UMAMI_DB_PASSWORD=

# Random secret used by Umami to encrypt session data (e.g. `openssl rand -hex 32`)
UMAMI_APP_SECRET=

# Set after registering the site in the Umami admin UI; used at Astro build time
PUBLIC_UMAMI_WEBSITE_ID=
